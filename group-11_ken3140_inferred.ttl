###  http://www.example.org/ontologies/ont.owl#BodyPart
<http://www.example.org/ontologies/ont.owl#BodyPart> rdf:type owl:Class .


###  http://www.example.org/ontologies/ont.owl#Formulation
<http://www.example.org/ontologies/ont.owl#Formulation> rdf:type owl:Class .


###  http://www.example.org/ontologies/ont.owl#ProductPurpose
<http://www.example.org/ontologies/ont.owl#ProductPurpose> rdf:type owl:Class .


###  http://www.example.org/ontologies/ont.owl#ScentFamily
<http://www.example.org/ontologies/ont.owl#ScentFamily> rdf:type owl:Class .


###  https://schema.org/Audience
<https://schema.org/Audience> rdf:type owl:Class .


###  https://schema.org/Brand
<https://schema.org/Brand> rdf:type owl:Class ;
                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                             owl:onProperty <https://www.theperfumeshop.com/ontology/isBrandOf> ;
                                             owl:someValuesFrom <https://schema.org/Product>
                                           ] .


###  https://schema.org/Female
<https://schema.org/Female> rdf:type owl:Class ;
                            rdfs:subClassOf <https://schema.org/Audience> ;
                            owl:disjointWith <https://schema.org/Male> .


###  https://schema.org/Male
<https://schema.org/Male> rdf:type owl:Class ;
                          rdfs:subClassOf <https://schema.org/Audience> .


###  https://schema.org/Product
<https://schema.org/Product> rdf:type owl:Class ;
                             rdfs:subClassOf [ rdf:type owl:Restriction ;
                                               owl:onProperty <https://www.theperfumeshop.com/ontology/hasCategory> ;
                                               owl:someValuesFrom <https://www.theperfumeshop.com/ontology/Category>
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <https://www.theperfumeshop.com/ontology/hasBrand> ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass <https://schema.org/Brand>
                                             ] .


###  https://www.theperfumeshop.com/ontology/Amber
<https://www.theperfumeshop.com/ontology/Amber> rdf:type owl:Class ;
                                                owl:equivalentClass [ owl:intersectionOf ( <https://schema.org/Product>
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://www.example.org/ontologies/ont.owl#hasFormulation> ;
                                                                                             owl:hasValue <http://www.example.org/ontologies/ont.owl#Spray>
                                                                                           ]
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://www.example.org/ontologies/ont.owl#hasScentFamily> ;
                                                                                             owl:hasValue <http://www.example.org/ontologies/ont.owl#AmberFamily>
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                rdfs:subClassOf <https://www.theperfumeshop.com/ontology/Fragrance> .


###  https://www.theperfumeshop.com/ontology/Category
<https://www.theperfumeshop.com/ontology/Category> rdf:type owl:Class ;
                                                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                     owl:onProperty <https://www.theperfumeshop.com/ontology/hasSubcategory> ;
                                                                     owl:someValuesFrom <https://www.theperfumeshop.com/ontology/Category>
                                                                   ] .


###  https://www.theperfumeshop.com/ontology/FaceBody
<https://www.theperfumeshop.com/ontology/FaceBody> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://www.theperfumeshop.com/ontology/Category> .


