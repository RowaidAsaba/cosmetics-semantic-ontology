@prefix : <http://www.semanticweb.org/rowaidasaba/ontologies/2025/8/untitled-ontology-12/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/rowaidasaba/ontologies/2025/8/untitled-ontology-12/> .

<http://www.semanticweb.org/rowaidasaba/ontologies/2025/8/untitled-ontology-12> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/ontologies/ont.owl#hasFormulation
<http://www.example.org/ontologies/ont.owl#hasFormulation> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <https://schema.org/Product> ;
                                                           rdfs:range <http://www.example.org/ontologies/ont.owl#Formulation> .


###  http://www.example.org/ontologies/ont.owl#hasPurpose
<http://www.example.org/ontologies/ont.owl#hasPurpose> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://schema.org/Product> ;
                                                       rdfs:range <http://www.example.org/ontologies/ont.owl#ProductPurpose> .


###  http://www.example.org/ontologies/ont.owl#hasScentFamily
<http://www.example.org/ontologies/ont.owl#hasScentFamily> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <https://schema.org/Product> ;
                                                           rdfs:range <http://www.example.org/ontologies/ont.owl#ScentFamily> .


###  http://www.example.org/ontologies/ont.owl#isAppliedTo
<http://www.example.org/ontologies/ont.owl#isAppliedTo> rdf:type owl:ObjectProperty ;
                                                        rdfs:domain <https://schema.org/Product> ;
                                                        rdfs:range <http://www.example.org/ontologies/ont.owl#BodyPart> .


###  https://www.theperfumeshop.com/ontology/forAudience
<https://www.theperfumeshop.com/ontology/forAudience> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <https://schema.org/Product> ;
                                                      rdfs:range <https://schema.org/Audience> .


###  https://www.theperfumeshop.com/ontology/hasBrand
<https://www.theperfumeshop.com/ontology/hasBrand> rdf:type owl:ObjectProperty ;
                                                   owl:inverseOf <https://www.theperfumeshop.com/ontology/isBrandOf> ;
                                                   rdf:type owl:FunctionalProperty ;
                                                   rdfs:domain <https://schema.org/Product> ;
                                                   rdfs:range <https://schema.org/Brand> .


###  https://www.theperfumeshop.com/ontology/hasCategory
<https://www.theperfumeshop.com/ontology/hasCategory> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain <https://schema.org/Product> ;
                                                      rdfs:range <https://www.theperfumeshop.com/ontology/Category> ;
                                                      owl:propertyChainAxiom ( <https://www.theperfumeshop.com/ontology/hasCategory>
                                                                               <https://www.theperfumeshop.com/ontology/hasSubcategory>
                                                                             ) .


###  https://www.theperfumeshop.com/ontology/hasFragranceFamily
<https://www.theperfumeshop.com/ontology/hasFragranceFamily> rdf:type owl:ObjectProperty ;
                                                             rdfs:subPropertyOf <https://www.theperfumeshop.com/ontology/hasCategory> ;
                                                             rdfs:domain <https://schema.org/Product> ;
                                                             rdfs:range <https://www.theperfumeshop.com/ontology/Fragrance> .


###  https://www.theperfumeshop.com/ontology/hasGiftType
<https://www.theperfumeshop.com/ontology/hasGiftType> rdf:type owl:ObjectProperty ;
                                                      rdfs:subPropertyOf <https://www.theperfumeshop.com/ontology/hasCategory> ;
                                                      rdfs:domain <https://schema.org/Product> ;
                                                      rdfs:range <https://www.theperfumeshop.com/ontology/Gifts> .


###  https://www.theperfumeshop.com/ontology/hasSubcategory
<https://www.theperfumeshop.com/ontology/hasSubcategory> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf <https://www.theperfumeshop.com/ontology/hasCategory> ;
                                                         rdf:type owl:AsymmetricProperty ,
                                                                  owl:TransitiveProperty ;
                                                         rdfs:domain <https://www.theperfumeshop.com/ontology/Category> ;
                                                         rdfs:range <https://www.theperfumeshop.com/ontology/Category> .


###  https://www.theperfumeshop.com/ontology/isBrandOf
<https://www.theperfumeshop.com/ontology/isBrandOf> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://schema.org/Brand> ;
                                                    rdfs:range <https://schema.org/Product> .


###  https://www.theperfumeshop.com/ontology/isSimilarTo
<https://www.theperfumeshop.com/ontology/isSimilarTo> rdf:type owl:ObjectProperty ,
                                                               owl:SymmetricProperty ;
                                                      rdfs:domain <https://schema.org/Product> ;
                                                      rdfs:range <https://schema.org/Product> .


#################################################################
#    Data properties
#################################################################

###  https://schema.org/name
<https://schema.org/name> rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf owl:topDataProperty .


###  https://schema.org/price
<https://schema.org/price> rdf:type owl:DatatypeProperty ;
                           rdfs:domain <https://schema.org/Product> ;
                           rdfs:range xsd:double .


###  https://schema.org/size
<https://schema.org/size> rdf:type owl:DatatypeProperty ;
                          rdfs:domain <https://schema.org/Product> ;
                          rdfs:range xsd:int .


###  https://www.theperfumeshop.com/ontology/concentration
<https://www.theperfumeshop.com/ontology/concentration> rdf:type owl:DatatypeProperty ;
                                                        rdfs:domain <https://schema.org/Product> ;
                                                        rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://theperfumeshop.com/ontology/webshop.owl#BodyCare
<http://theperfumeshop.com/ontology/webshop.owl#BodyCare> rdf:type owl:Class ;
                                                          rdfs:subClassOf <https://www.theperfumeshop.com/ontology/FaceBody> .


###  http://theperfumeshop.com/ontology/webshop.owl#BodyLotion
<http://theperfumeshop.com/ontology/webshop.owl#BodyLotion> rdf:type owl:Class ;
                                                            owl:equivalentClass [ owl:intersectionOf ( <https://schema.org/Product>
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty <http://www.example.org/ontologies/ont.owl#hasFormulation> ;
                                                                                                         owl:hasValue <https://www.theperfumeshop.com/ontology/Lotion>
                                                                                                       ]
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty <http://www.example.org/ontologies/ont.owl#isAppliedTo> ;
                                                                                                         owl:hasValue <https://www.theperfumeshop.com/ontology/Body>
                                                                                                       ]
                                                                                                     ) ;
                                                                                  rdf:type owl:Class
                                                                                ] ;
                                                            rdfs:subClassOf <http://theperfumeshop.com/ontology/webshop.owl#BodyCare> .


