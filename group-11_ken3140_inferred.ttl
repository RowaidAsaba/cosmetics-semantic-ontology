                                                                                                       owl:hasValue <https://www.theperfumeshop.com/ontology/Body>
                                                                                                     ]
                                                                                                   ) ;
                                                                                rdf:type owl:Class
                                                                              ] ;
                                                          rdfs:subClassOf <http://theperfumeshop.com/ontology/webshop.owl#FaceCare> .


